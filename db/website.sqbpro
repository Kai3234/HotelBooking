(MaKH, TongTien, NgayTao, ThanhToan, TrangThai, MaNV, GhiChu)
VALUES
(1, 2500000, '2026-04-04', 0, 'Đã xác nhận', 1, 'Khách đến buổi tối'),

(2, 4200000, '2026-04-04', 1, 'Đang lưu trú', 2, 'Khách VIP'),

(3, 1800000, '2026-04-05', 0, 'Chờ xác nhận', 1, 'Đặt online');

SELECT MaDP FROM DATPHONG;

SELECT MaPhong FROM PHONG;

SELECT MaLoai FROM LOAIPHONG;

